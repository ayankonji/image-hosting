# 图片托管仓库 .gitignore

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
*.log

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo

# Python相关
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# 上传的图片（取消注释以忽略）
# images/*.jpg
# images/*.jpeg
# images/*.png
# images/*.gif
# images/*.webp

# 配置文件（包含敏感信息）
config.json
.env
.env.local

# 上传记录
uploaded_urls.txt
upload_log.txt

# 其他
*.bak
*.backup
*.old