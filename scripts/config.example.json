{
    "github": {
        "token": "your_github_token_here",
        "username": "your_github_username",
        "repo": "image-hosting",
        "branch": "main"
    },
    "upload": {
        "max_file_size_mb": 10,
        "allowed_extensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp"],
        "auto_rename": true,
        "prefix": "img"
    },
    "urls": {
        "base_url": "https://{username}.github.io/{repo}/images",
        "format": "https://{username}.github.io/{repo}/images/{filename}"
    }
}